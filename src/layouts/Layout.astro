---
import '@fontsource-variable/montserrat';
import '@fontsource-variable/open-sans';
import '../styles/global.css';

import StickyWhatsApp from '../components/StickyWhatsApp.astro';
import { siteConfig } from '../data/siteConfig.ts';
import { getBaseSchema } from '../utils/seo.ts';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  noindex?: boolean;
}

const {
  title = siteConfig.seo.defaultTitle,
  description = siteConfig.seo.defaultDescription,
  canonical,
  ogImage = `${siteConfig.seo.url}/og-white.svg`,
  robots,
  noindex = false,
} = Astro.props;

const pathname = Astro.url?.pathname ?? '/';
const canonicalUrl = canonical ?? new URL(pathname, siteConfig.seo.url).toString();
const robotsContent = noindex
  ? 'noindex, nofollow'
  : robots ?? 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

// Holt sich das saubere JSON-LD Objekt aus unserem neuen Helper
const structuredData = getBaseSchema(title, description, canonicalUrl, ogImage);
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=yes, address=yes, email=yes" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={siteConfig.company.owner} />
    <meta name="theme-color" content="#09090b" />

    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href="/faviconwhite.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={siteConfig.company.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Marcel van Lier Objektaufbereitung – Spezialreinigung und Bauendreinigung im Ruhrgebiet" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Marcel van Lier Objektaufbereitung – Spezialreinigung und Bauendreinigung im Ruhrgebiet" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </head>

  <body class="overflow-x-hidden bg-[#09090b] text-zinc-100 antialiased selection:bg-zinc-100 selection:text-[#09090b]">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-white focus:p-4 focus:text-black"
    >
      Zum Hauptinhalt springen
    </a>

    <main id="main-content">
      <slot />
    </main>

    <StickyWhatsApp />

    <script is:inline>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const revealEverything = () => {
        document.querySelectorAll('.motion-hero, .motion-scroll').forEach((el) => {
          el.classList.add('is-visible');
        });
        const img = document.getElementById('hero-img');
        if (img) img.classList.replace('scale-110', 'scale-100');
      };

      const runAnimations = () => {
        if (prefersReducedMotion || !('IntersectionObserver' in window)) {
          revealEverything();
          return;
        }

        setTimeout(() => {
          document.querySelectorAll('.motion-hero').forEach((el) => el.classList.add('is-visible'));
          const img = document.getElementById('hero-img');
          if (img) img.classList.replace('scale-110', 'scale-100');
        }, 50);

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );

        document.querySelectorAll('.motion-scroll').forEach((el) => observer.observe(el));
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runAnimations, { once: true });
      } else {
        runAnimations();
      }
    </script>
  </body>
</html>