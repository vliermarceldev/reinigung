---
import { Image } from 'astro:assets';
import heroBg from '../assets/herobg-website.webp';
import ContactCtas from '../components/ContactCtas.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';
import Process from '../components/Process.astro';
import Services from '../components/Services.astro';
import Trust from '../components/Trust.astro';
import type { CityEntry } from '../data/cities.ts';
import { cityData, getCityMeta } from '../data/cities.ts';
import { siteConfig } from '../data/siteConfig.ts';
import Layout from '../layouts/Layout.astro';
import { getFaqSchema } from '../utils/seo.ts';

export function getStaticPaths() {
  return cityData.map((data) => ({
    params: { city: data.slug },
    props: { cityInfo: data },
  }));
}

export interface Props {
  cityInfo: CityEntry;
}

const { cityInfo } = Astro.props;

// Meta-Infos und SEO-Schema generieren wir jetzt über unsere Helfer
const { title: metaTitle, description: metaDesc } = getCityMeta(cityInfo.name);
const schemaOrgLocalFaq = getFaqSchema(cityInfo.faqs);
---

<Layout title={metaTitle} description={metaDesc}>
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaOrgLocalFaq)} />

  <header class="relative min-h-[90dvh] w-full flex items-center bg-black overflow-hidden border-b border-zinc-900">
    <Image 
      src={heroBg} 
      alt={`Spezialreinigung in ${cityInfo.name}`}
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#09090b] via-black/80 to-black/40 z-0 pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 py-24 mt-10">
      <div class="w-full max-w-2xl">
        <span class="eyebrow motion-hero inline-block px-4 py-1.5 mb-6 border border-emerald-500/30 bg-emerald-500/10 backdrop-blur-md text-emerald-400 text-xs tracking-widest uppercase rounded-sm font-bold">
          Einsatzort: {cityInfo.name}
        </span>
        
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight">
          <span class="motion-hero block delay-100 pb-1">Spezialreinigung</span>
          <span class="motion-hero block text-zinc-400 delay-200">{cityInfo.h1Sub}</span>
        </h1>
        
        <p class="motion-hero delay-300 text-lg md:text-xl text-zinc-300 mb-10 leading-relaxed">
          Verlässliche Bauendreinigung, Grundreinigung und Härtefall-Aufbereitung für Hausverwaltungen, Gewerbe und Eigentümer in {cityInfo.name}.
          <strong class="text-white font-semibold">Senden Sie uns aussagekräftige Fotos Ihres Objekts – Sie erhalten {siteConfig.cta.promiseText}.</strong>
        </p>

        <ContactCtas city={cityInfo.name} variant="hero" class="motion-hero delay-400 mb-8" />

        <div class="motion-hero delay-500">
          <a href="#lokale-infos" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-emerald-400 transition-colors">
            Mehr zu {cityInfo.name} <span aria-hidden="true">&darr;</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <section id="lokale-infos" class="bg-[#09090b] py-16 lg:py-24 px-6 border-b border-zinc-900">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <div class="motion-scroll">
        <h2 class="text-3xl font-extrabold text-white mb-6 tracking-tight">{cityInfo.introTitle}</h2>
        <p class="text-zinc-400 leading-relaxed mb-6">{cityInfo.introText}</p>
        
        <div class="bg-zinc-900/50 border border-zinc-800 p-6 rounded-md">
          <h3 class="text-emerald-400 font-bold uppercase tracking-wider text-xs mb-3">Anfahrt & Logistik in {cityInfo.name}</h3>
          <p class="text-zinc-300 text-sm leading-relaxed">{cityInfo.logistics}</p>
        </div>
      </div>

      <div class="motion-scroll delay-100">
        <h3 class="text-2xl font-bold text-white mb-6 tracking-tight">Häufige Fragen ({cityInfo.name})</h3>
        <div id="faq" class="flex flex-col border-t border-zinc-800">
          {cityInfo.faqs.map((faq) => (
            <details class="group border-b border-zinc-800 py-4">
              <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-zinc-200 text-sm [&::-webkit-details-marker]:hidden hover:text-white transition-colors">
                <span class="pr-6">{faq.q}</span>
                <span class="transition-transform duration-300 group-open:rotate-180 text-emerald-500 shrink-0">
                  <svg fill="none" height="16" width="16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <p class="text-zinc-400 leading-relaxed text-sm mt-3 pr-8">
                {faq.a}
              </p>
            </details>
          ))}
        </div>
      </div>

    </div>
  </section>

  <Marquee />
  <Services />
  <Trust />
  <Process />
  
  <Footer />
</Layout>