---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig.ts';

const metaTitle = `Seite nicht gefunden | ${siteConfig.company.name}`;
const metaDesc = "Die gesuchte Seite existiert leider nicht. Kehren Sie zurück zur Startseite für alle Informationen rund um unsere Spezialreinigung.";
---

<Layout title={metaTitle} description={metaDesc} noindex={true}>
  <section class="min-h-[80dvh] flex items-center justify-center px-6 relative overflow-hidden">
    
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-emerald-500/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-xl mx-auto text-center relative z-10 motion-scroll">
      <span class="inline-block px-4 py-1.5 mb-6 border border-emerald-500/30 bg-emerald-500/10 backdrop-blur-md text-emerald-400 text-xs tracking-widest uppercase rounded-sm font-bold">
        Fehler 404
      </span>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight">
        Seite nicht gefunden.
      </h1>
      
      <p class="text-zinc-400 text-lg leading-relaxed mb-10">
        Die Adresse ist entweder veraltet, falsch geschrieben oder die Seite wurde verschoben. Lassen Sie uns zurück zum Wesentlichen gehen.
      </p>

      <a href="/" class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-zinc-200 text-black font-extrabold rounded-md transition-colors duration-300 text-sm tracking-wide uppercase">
        Zurück zur Startseite
      </a>
    </div>
  </section>
</Layout>