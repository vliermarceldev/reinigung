---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const metaTitle = "Impressum | Spezialreinigung Ruhrgebiet";
const metaDesc = "Impressum und rechtliche Hinweise gemäß § 5 TMG.";
---

<Layout title={metaTitle} description={metaDesc}>
  <header class="border-b border-zinc-900 bg-[#09090b] px-6 pb-12 pt-24">
    <div class="mx-auto max-w-3xl">
      <a
        href="/"
        class="mb-6 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-zinc-500 transition-colors hover:text-white"
      >
        <span aria-hidden="true">&larr;</span> Zurück zur Startseite
      </a>
      <h1 class="motion-hero text-4xl font-extrabold tracking-tight text-white md:text-5xl">
        Impressum.
      </h1>
    </div>
  </header>

  <section class="min-h-[50vh] bg-[#09090b] px-6 py-16">
    <div class="prose prose-sm md:prose-base prose-zinc prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-green-500 hover:prose-a:text-green-400 mx-auto max-w-3xl">
      <h2>Angaben gemäß § 5 TMG</h2>
      <p>
        <strong>Marcel van Lier</strong><br />
        Objektaufbereitung Ruhrgebiet<br />
        Vor dem Falltor 11<br />
        46459 Rees
      </p>

      <h2>Kontakt</h2>
      <p>
        Telefon: +49(0)17620013611<br />
        E-Mail: <a href="mailto:kontakt@lier-objektaufbereitung.de">kontakt@lier-objektaufbereitung.de</a>
      </p>

      <h2>Umsatzsteuer-ID</h2>
      <p>
        Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
        DE999999999
      </p>

      <h2>Verbraucherstreitbeilegung/Universalschlichtungsstelle</h2>
      <p>
        Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
        Verbraucherschlichtungsstelle teilzunehmen.
      </p>
    </div>
  </section>

  <Footer />
</Layout>