---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Services from '../components/Services.astro';
import Trust from '../components/Trust.astro';
import Process from '../components/Process.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const metaTitle = "Spezialreinigung Ruhrgebiet | Profi-Einsatz bei Bau & Härtefällen";
const metaDesc = "Spezialreinigung im Ruhrgebiet: Bauendreinigung, Grundreinigung und Härtefälle. Schnell, professionell, direkt per Fotoanfrage. Jetzt Angebot einholen.";
---

<Layout title={metaTitle} description={metaDesc}>
  <Hero />

  <Marquee />
  <Services />
  <Trust />
  <Process />
  <FAQ />

  <Footer />
</Layout>