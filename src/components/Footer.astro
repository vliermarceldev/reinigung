---
import { siteConfig } from '../data/siteConfig.ts';
import ContactCtas from './ContactCtas.astro';

interface Props {
  hideContact?: boolean;
}

const { hideContact = false } = Astro.props;
---
<footer id={hideContact ? undefined : "kontakt"} class={`bg-black text-zinc-100 px-6 border-t border-zinc-900 ${hideContact ? 'py-8' : 'py-16 lg:py-32'}`} aria-labelledby={hideContact ? undefined : "footer-heading"}>
  
  {!hideContact && (
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start mb-24">
      
      <div>
        <h2 id="footer-heading" class="motion-scroll text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">Lassen Sie uns starten.</h2>
        <p class="motion-scroll delay-100 text-zinc-400 text-lg leading-relaxed mb-10">
          Beschreiben Sie kurz Ihr Anliegen oder senden Sie direkt Fotos Ihres Objekts.
          Sie erhalten <strong class="text-white font-semibold">{siteConfig.cta.promiseText}</strong> zum Aufwand und zur passenden Ausführung.
        </p>
        
        <ContactCtas variant="footer" class="motion-scroll delay-200 mb-16 lg:mb-0" />
      </div>

      <div class="motion-scroll delay-300 bg-zinc-950 p-8 border border-zinc-800 rounded-xl shadow-2xl relative">
        <h3 class="text-xl font-bold text-white mb-6">Direktanfrage senden</h3>
        
<form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5" enctype="multipart/form-data">
  
  <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY}>
  <input type="hidden" name="subject" value="Neue Website-Anfrage (Spezialreinigung)">
  <input type="hidden" name="from_name" value={siteConfig.company.name}>
  <input type="hidden" name="redirect" value={`${siteConfig.seo.url}/danke`}>
  
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
  
  <div>
    <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-2">Name oder Firma <span class="text-emerald-500" aria-hidden="true">*</span></label>
    <input type="text" id="name" name="name" required autocomplete="name" placeholder="Max Mustermann / Muster GmbH" class="w-full bg-[#09090b] border border-zinc-800 rounded-md px-4 py-3 text-zinc-300 placeholder:text-zinc-700 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors">
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-2">E-Mail Adresse <span class="text-emerald-500" aria-hidden="true">*</span></label>
      <input type="email" id="email" name="email" required autocomplete="email" placeholder="mail@beispiel.de" class="w-full bg-[#09090b] border border-zinc-800 rounded-md px-4 py-3 text-zinc-300 placeholder:text-zinc-700 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors">
    </div>
    <div>
      <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-2">Telefon <span class="text-zinc-600 font-normal lowercase tracking-normal">(optional)</span></label>
      <input type="tel" id="phone" name="phone" autocomplete="tel" inputmode="tel" placeholder="0151 12345678" class="w-full bg-[#09090b] border border-zinc-800 rounded-md px-4 py-3 text-zinc-300 placeholder:text-zinc-700 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors">
    </div>
  </div>

  <div>
    <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-2">Nachricht <span class="text-emerald-500" aria-hidden="true">*</span></label>
    <textarea id="message" name="message" required rows="4" placeholder="Objektart, Standort und kurze Beschreibung Ihres Anliegens..." class="w-full bg-[#09090b] border border-zinc-800 rounded-md px-4 py-3 text-zinc-300 placeholder:text-zinc-700 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors resize-none"></textarea>
  </div>

  <div>
    <label for="attachment" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-2">Fotos anhängen <span class="text-zinc-600 font-normal lowercase tracking-normal">(optional)</span></label>
    <input type="file" id="attachment" name="attachment" accept="image/png, image/jpeg, image/webp" multiple class="w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-xs file:font-bold file:uppercase file:tracking-wider file:bg-zinc-800 file:text-zinc-300 hover:file:bg-zinc-700 transition-colors cursor-pointer">
    <p class="text-[10px] text-zinc-500 mt-2 font-medium tracking-wide">Maximal 5 Bilder (JPG, PNG, WebP). Gesamtgröße bis 10 MB.</p>
    <p id="file-error" class="text-[10px] text-red-400 mt-1 font-bold hidden"></p>
  </div>

  <div class="h-captcha mt-2" data-captcha="true"></div>

  <div class="pt-2">
    <button type="submit" id="submit-button" class="w-full px-8 py-4 bg-emerald-500 hover:bg-emerald-400 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-emerald-500 text-zinc-950 font-extrabold rounded-md transition-all duration-300 text-sm tracking-wide uppercase shadow-[0_0_15px_rgba(16,185,129,0.2)] focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-[#09090b] flex items-center justify-center gap-2">
      <span id="submit-text">Anfrage abschicken</span>
      <svg id="submit-spinner" class="animate-spin h-5 w-5 text-zinc-950 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </button>
    <p class="text-center text-[10px] text-zinc-400 mt-3 flex items-center justify-center gap-1.5 uppercase tracking-widest font-semibold">
      <svg class="w-3 h-3 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      {siteConfig.cta.promiseText}
    </p>
  </div>
</form>
      </div>

    </div>
  )}

  <div class={`max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4 font-medium tracking-wide text-zinc-600 text-xs ${!hideContact ? 'border-t border-zinc-900 pt-10' : ''}`}>
    <p>&copy; <span id="current-year"></span> {siteConfig.company.name}. Alle Rechte vorbehalten.</p>
    
    <nav aria-label="Footer Navigation" class="flex flex-wrap items-center justify-center sm:justify-end gap-x-6 gap-y-3 mt-4 sm:mt-0">
      <div class="flex flex-wrap items-center gap-4 border-b sm:border-b-0 sm:border-r border-zinc-800 pb-3 sm:pb-0 sm:pr-6 mb-1 sm:mb-0">
        <a href="/spezialreinigung-essen" class="hover:text-zinc-300 transition-colors">Essen</a>
        <a href="/spezialreinigung-dortmund" class="hover:text-zinc-300 transition-colors">Dortmund</a>
        <a href="/spezialreinigung-duesseldorf" class="hover:text-zinc-300 transition-colors">Düsseldorf</a>
      </div>
      <a href="/impressum" class="hover:text-zinc-300 transition-colors">Impressum</a>
      <a href="/datenschutz" class="hover:text-zinc-300 transition-colors">Datenschutz</a>
    </nav>
  </div>
</footer>

{!hideContact && <script is:inline src="https://web3forms.com/client/script.js" async defer></script>}

<script>
  // Strictly typed DOM queries
  const yearEl = document.getElementById('current-year') as HTMLSpanElement | null;
  if (yearEl) {
    yearEl.textContent = new Date().getFullYear().toString();
  }

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const fileInput = document.getElementById('attachment') as HTMLInputElement | null;
  const fileError = document.getElementById('file-error') as HTMLParagraphElement | null;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement | null;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement | null;
  const submitSpinner = document.getElementById('submit-spinner') as SVGSVGElement | null;

  // 1. Harte Datei-Validierung
  if (fileInput && fileError && submitButton) {
    fileInput.addEventListener('change', function(this: HTMLInputElement) {
      const files = this.files;
      if (!files) return;

      let totalSize = 0;
      let errorMessage = '';
      const MAX_FILES = 5;
      const MAX_SIZE_MB = 10;
      const MAX_SIZE_BYTES = MAX_SIZE_MB * 1024 * 1024;

      if (files.length > MAX_FILES) {
        errorMessage = `Bitte maximal ${MAX_FILES} Bilder auswählen.`;
      } else {
        for (let i = 0; i < files.length; i++) {
          totalSize += files[i].size;
        }
        if (totalSize > MAX_SIZE_BYTES) {
          errorMessage = `Die Gesamtgröße der Bilder darf ${MAX_SIZE_MB} MB nicht überschreiten (Aktuell: ${(totalSize / 1024 / 1024).toFixed(1)} MB).`;
        }
      }

      if (errorMessage) {
        fileError.textContent = errorMessage;
        fileError.classList.remove('hidden');
        submitButton.disabled = true;
        
        // WICHTIG: Das Input-Feld hart leeren, damit die ungültigen Dateien
        // physisch nicht mehr im Formular-Payload hängen!
        this.value = ''; 
      } else {
        fileError.textContent = '';
        fileError.classList.add('hidden');
        submitButton.disabled = false;
      }
    });
  }

  // 2. Ladezustand & Doppel-Klick-Sperre
  if (form && submitButton && submitText && submitSpinner) {
    form.addEventListener('submit', () => {
      // Button sperren und optisch Feedback geben
      submitButton.disabled = true;
      submitButton.classList.add('cursor-wait');
      if (submitText) submitText.textContent = 'Wird gesendet...';
      if (submitSpinner) submitSpinner.classList.remove('hidden');
    });
  }
</script>