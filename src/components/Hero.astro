---
import { Image } from 'astro:assets';
import heroBg from '../assets/herobg-website.webp';
import ContactCtas from './ContactCtas.astro';
import { siteConfig } from '../data/siteConfig.ts';

interface Props {
  city?: string;
}

const { city } = Astro.props;
const eyebrowText = city ? `Einsatzort: ${city}` : siteConfig.company.region;
const locationText = city ? ` in ${city}` : "";
---
<header class="relative min-h-[100dvh] w-full flex items-center bg-black overflow-hidden">
  
  <Image 
    id="hero-img" 
    src={heroBg} 
    alt={city ? `Spezialreinigung in ${city}` : "Profi bei der Spezialreinigung"}
    fetchpriority="high"
    loading="eager"
    decoding="sync"
    class="absolute inset-0 w-full h-full object-cover object-center opacity-80"
  />
  
  <div class="absolute inset-0 bg-black/80 z-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 py-24">
    <div class="w-full max-w-2xl">
      
      <span class="eyebrow motion-hero inline-block px-4 py-1.5 mb-6 border border-white/10 bg-white/5 backdrop-blur-md text-zinc-300 text-xs tracking-widest uppercase rounded-sm font-semibold">
        {eyebrowText}
      </span>
      
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight drop-shadow-lg">
        <span class="motion-hero block delay-100">
          <span class="pb-1">
            Spezialreinigung
          </span>
        </span>
        <span class="motion-hero block text-white delay-200">für Objekte mit</span>
        <span class="motion-hero block text-white delay-300">erhöhtem Anspruch.</span>
      </h1>
      
      <p class="motion-hero delay-400 text-lg md:text-xl text-zinc-300 mb-10 leading-relaxed drop-shadow-md">
        Verlässliche Bauendreinigung, Grundreinigung und Härtefall-Aufbereitung für Hausverwaltungen, Gewerbe und Eigentümer{locationText}.
        <strong class="text-white font-semibold">Senden Sie uns aussagekräftige Fotos Ihres Objekts – Sie erhalten {siteConfig.cta.promiseText}.</strong>
      </p>
      
      <ContactCtas city={city} variant="hero" class="motion-hero delay-500" />
      
    </div>
  </div>
</header>