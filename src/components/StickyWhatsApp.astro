      rel="noopener noreferrer"
      aria-label="Direkt per WhatsApp anfragen"
      class="relative flex items-center justify-center w-14 h-14 bg-emerald-500 text-zinc-950 rounded-full shadow-[0_0_20px_rgba(16,185,129,0.5)] transition-transform duration-300 active:scale-95"
    >
