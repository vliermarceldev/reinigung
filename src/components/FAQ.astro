---
import { globalFaqs } from '../data/globalFaqs.ts';
import { getFaqSchema } from '../utils/seo.ts';

const schemaOrgFaq = getFaqSchema(globalFaqs);
---

<section id="faq" class="py-16 lg:py-32 px-6 max-w-4xl mx-auto border-b border-zinc-900" aria-labelledby="faq-heading">
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaOrgFaq)} />

  <div class="mb-12 lg:mb-16">
    <h2 id="faq-heading" class="motion-scroll text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">Häufige Fragen.</h2>
    <p class="motion-scroll delay-100 text-zinc-400 text-lg leading-relaxed">Klare Informationen für eine planbare und reibungslose Zusammenarbeit.</p>
  </div>
  
  <div class="flex flex-col">
    {globalFaqs.map((faq, index) => (
      <details class={`motion-scroll group border-b border-zinc-800/60 py-5 ${index % 2 !== 0 ? 'delay-100' : ''}`}>
        <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-white text-base lg:text-lg [&::-webkit-details-marker]:hidden">
          <span class="pr-6">{index + 1}. {faq.q}</span>
          <span class="transition-transform duration-300 group-open:rotate-180 text-zinc-500 shrink-0">
            <svg fill="none" height="20" width="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-zinc-400 leading-relaxed text-sm mt-4 pr-12">
          {faq.a}
        </p>
      </details>
    ))}
  </div>
</section>